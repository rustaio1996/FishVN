{
  "name": "ngu-ong-bat-on",
  "version": "0.3.3",
  "description": "New Version - fishing idle game desktop build",
  "main": "electron/main.js",
  "private": true,
  "author": "Ngu Ong Bat On Team",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:apk": "powershell -ExecutionPolicy Bypass -File scratch/build-apk.ps1",
    "check:js": "node --check js/modules/i18n.js && node --check js/modules/audio.js && node --check js/modules/time-events.js && node --check js/game-state.js && node --check js/data/world-data.js && node --check js/data/progression-data.js && node --check js/game-core.js && node --check electron/main.js",
    "analyze:fish": "node scratch/analyze_fish_balance.js",
    "simulate:fish": "node scratch/simulate_fish_rolls.js",
    "simulate:economy": "node scratch/simulate_economy.js"
  },
  "build": {
    "appId": "com.nguongbaton.game",
    "productName": "New Version",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "NguOngBatOn.html",
      "assets/**/*",
      "css/**/*",
      "js/**/*",
      "build/icon.ico",
      "build/icon.png",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}